MONGO_URI = mongodb://ridhijain2266:ridhi2986@ac-gltlsuk-shard-00-00.ujudeys.mongodb.net:27017,ac-gltlsuk-shard-00-01.ujudeys.mongodb.net:27017,ac-gltlsuk-shard-00-02.ujudeys.mongodb.net:27017/cluster0?ssl=true&replicaSet=atlas-slt63f-shard-0&authSource=admin&appName=Cluster0

# ─── CORS ──────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────
# Port the Express server listens on
PORT=5000

# Environment: development | production
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Local MongoDB instance. For MongoDB Atlas, replace with your
# connection string, e.g.:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/student_management?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://ridhijain2266:ridhi@2986@cluster0.ujudeys.mongodb.net/student_management?retryWrites=true&w=majority

# ─── CORS ──────────────────────────────────────────────────
# URL of the frontend allowed to call this API.
# Use * only for local testing — set an explicit origin in production.
CLIENT_URL=http://localhost:5173
